# OpenRouter
OPENROUTER_API_KEY=<SUAKEY>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_CHAT=openrouter/free
OPENROUTER_MODEL_EMBED=nvidia/llama-nemotron-embed-vl-1b-v2:free

# OpenRouter Resilience
OPENROUTER_REQUEST_TIMEOUT_MS=10000
OPENROUTER_MAX_RETRIES=2
OPENROUTER_FALLBACK_CHAT=
OPENROUTER_FALLBACK_EMBED=

# Chroma
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=cv_chunks
CHROMA_PERSIST_DIR=./data/chroma

# API
PROFILE_ID_MAX_LENGTH=64
PORT=3000
HOST=0.0.0.0
MAX_UPLOAD_MB=10

# RAG Tuning
CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=5

# Operation
LOG_LEVEL=info
NODE_ENV=development

